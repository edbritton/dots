_shell="${ZSH_VERSION:+zsh}"
_shell="${_shell:-bash}"

if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv $_shell)"

  autoload -Uz compinit
  compinit
fi

# Load fzf bindings and autocompletes if installed
command -v fzf &>/dev/null && . <(fzf --"$_shell") # use fzf for history search

# Initiate starship if installed
command -v starship &>/dev/null && eval "$(starship init "$_shell")"

unset _shell
