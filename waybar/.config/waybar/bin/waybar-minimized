#!/bin/bash

restore() {
  local map
  map=$(mktemp /tmp/walker-minimize.XXXXXX)
  trap 'rm -f "$map"' EXIT

  hyprctl clients | awk '
    BEGIN { RS=""; FS="\n" }

    /special:minimize/ {
      addr = ""; cls = ""; title = ""
      for (i = 1; i <= NF; i++) {
        if ($i ~ /^Window /) {
          split($i, w, " ")
          addr = "0x" w[2]
          sub(/->$/, "", addr)
        }
        if ($i ~ /^[[:space:]]*class:/)  cls   = substr($i, index($i, ":") + 2)
        if ($i ~ /^[[:space:]]*title:/)  title = substr($i, index($i, ":") + 2)
      }
      print addr "|" cls " - " title
    }
  ' > "$map"

  local count
  count=$(wc -l < "$map")

  if [ "$count" -eq 0 ]; then
    notify-send "Minimize" "No minimized windows" -t 2000
    exit 0
  fi

  # Single window — restore directly
  if [ "$count" -eq 1 ]; then
    local addr
    addr=$(cut -d'|' -f1 < "$map")
    hyprctl dispatch movetoworkspace +0,address:"$addr"
    pkill -RTMIN+12 waybar 2>/dev/null
    exit 0
  fi

  # Multiple windows — show picker
  local pick
  pick=$(cut -d'|' -f2- < "$map" | walker -d -p "Restore:")

  if [ -z "$pick" ]; then
    exit 0
  fi

  local addr
  addr=$(grep -F "|${pick}" "$map" | cut -d'|' -f1)

  if [ -n "$addr" ]; then
    hyprctl dispatch movetoworkspace +0,address:"$addr"
    pkill -RTMIN+12 waybar 2>/dev/null
  fi
}

menuextra() {
  num=$(hyprctl clients -j | jq -r '[.[] | select(.workspace.name == "special:minimize")] | length')
  winds=$(hyprctl clients -j | jq -r '.[] | select(.workspace.name == "special:minimize") | .class')

  case "$num" in
    0) icon="" ;;
    1) icon="\ueb7f" ;;
    *) icon="\ueb23" ;;
  esac

  list=""

  printf "{\"text\":\"$icon\",\"tooltip\":\"$list\",\"class\":\"has-minimized\"}"
}

case "${1:-}" in
  --restore) restore ;;
  *)         menuextra ;;
esac
