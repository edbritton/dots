# Window Management
unless server
  brew "asmvik/formulae/skhd"
  brew "asmvik/formulae/yabai"             # requires sudo manipulation for all features
  brew "dimentium/autoraise/autoraise"     # used as fallback when yabai is off
  brew "nowplaying-cli"                    # needed for one skhd keybind
  brew "displayplacer"                     # needed for one skhd keybind
  cask "middleclick"
end

