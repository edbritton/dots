# One brewfile, many machines
def laptop
  system("pmset -g batt 2>/dev/null | grep -q 'Battery'")
end
def min_ram(gb = 8)
  ram = `system_profiler SPMemoryDataType | sed -n 's/.*Memory: \([0-9]*\) GB/\1/p'`.to_i
  ram >= gb
end
def model(name)
  `system_profiler SPHardwareDataType 2>/dev/null | awk -F': ' '/Model Name:/ {print $2}'`.strip =~ name
end
def server
  !laptop && !model("iMac")
end

# Basics
brew "mas"
brew "stow"

# Terminal and shell upgrades
brew "bat"                                 # better cat
brew "eza"                                 # better ls
brew "fd"                                  # better find
brew "fdupes"                              # duplicate finder
brew "fzf"                                 # fuzzy find
brew "ripgrep"                             # better grep
brew "starship"
cask "font-fira-code-nerd-font" unless server

# Self-hosting and cross-platform
