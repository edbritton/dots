#cmd + lalt - tab : yabai -m window --focus stack.next || yabai -m window --focus stack.first

# Previous window in stack (Omarchy: SUPER SHIFT ALT + TAB)
#shift + lcmd + lalt - tab : yabai -m window --focus stack.prev || yabai -m window --focus stack.last

# Cycle between tiled windows
lalt - tab : yabai -m window --focus next || yabai -m window --focus first
shift + lalt - tab : yabai -m window --focus prev || yabai -m window --focus last

## Resize (ctrl + lalt - ...)
# Resize windows: ctrl + lalt - {j, k, l, ö}
#lalt - minus : yabai -m window --resize left:-100:0
#lalt - equal : yabai -m window --resize left:100:0
#shift + lalt - minus : yabai -m window --resize bottom:0:-100
#shift + lalt - equal : yabai -m window --resize bottom:0:100
ctrl + lalt - left  : yabai -m window --resize right:-100:0 || yabai -m window --resize left:-100:0
ctrl + lalt - down  : yabai -m window --resize bottom:0:100 || yabai -m window --resize top:0:100
ctrl + lalt - up    : yabai -m window --resize bottom:0:-100 || yabai -m window --resize top:0:-100
ctrl + lalt - right : yabai -m window --resize right:100:0 || yabai -m window --resize left:100:0

# Equalize size of windows: ctrl + lalt - e
ctrl + lalt - e : yabai -m space --balance

# Toggle space gaps (Omarchy: SHUPER SHIFT + BACKSPACE)
shift + lcmd - backspace : yabai -m space --toggle padding; yabai -m space --toggle gap
ctrl + lalt + lcmd - up   : yabai -m space --padding rel:7:8:8:8 && yabai -m space --gap rel:7
ctrl + lalt + lcmd - down : yabai -m space --padding rel:-7:-8:-8:-8 && yabai -m space --gap rel:-7
ctrl + lalt + lcmd - e    : yabai -m space --padding abs:7:8:8:8 && yabai -m space --gap abs:7

ctrl + lalt - b : yabai -m window --toggle border

## Insertion (shift + ctrl + lalt - ...)
# Set insertion point for focused container: shift + ctrl + lalt - {j, k, l, ö, s}
shift + ctrl + lalt - j : yabai -m window --insert west
shift + ctrl + lalt - k : yabai -m window --insert south
shift + ctrl + lalt - l : yabai -m window --insert north
shift + ctrl + lalt - 0x29 : yabai -m window --insert east
shift + ctrl + lalt - s : yabai -m window --insert stack>

# New window in hor./ vert. splits for all applications with yabai
lalt - s : yabai -m window --insert east;  skhd -k "cmd - n"
lalt - v : yabai -m window --insert south; skhd -k "cmd - n"

