ctrl - 8 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[8] ]] && yabai -m space --focus $SPACES[8]
ctrl - 9 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[9] ]] && yabai -m space --focus $SPACES[9]

# Focus on <ARROW> window (Omarchy: SUPER + <ARROW>)
lcmd - left  : yabai -m window --focus west  || yabai -m display --focus west
lcmd - down  : yabai -m window --focus south || yabai -m display --focus south
lcmd - up    : yabai -m window --focus north || yabai -m display --focus north
lcmd - right : yabai -m window --focus east  || yabai -m display --focus east

# Toggle window tiling (Omarchy: SUPER + T)
lalt - t : yabai -m window --toggle float

# Toggle space tiling
fn + lalt - t : yabai -m query --spaces --space | jq -e '.type == "bsp"' > /dev/null && yabai -m space --layout float || yabai -m space --layout bsp

# Square and centre this window
fn + ctrl + lalt - c   : pgrep -q yabai && { yabai -m window --grid 10:16:3:0:10:10; skhd -k 'fn + ctrl - c'; true; } || shortcuts run "Square the window"

# Full width (Omarchy: SUPER ALT + F)
lalt + lcmd - f : yabai -m window --toggle zoom-fullscreen # was: shift + lalt - f

# Fill current tree (Omarchy: not on Omarchy)
lalt - f : yabai -m window --toggle zoom-parent

# Swap window to the <ARROW> (Omarchy: SUPER SHIFT + <ARROW>)
shift + lcmd - left  : yabai -m window --swap west || $(yabai -m window --display west && yabai -m display --focus west && yabai -m window --warp last) || yabai -m window --move rel:-8:0
shift + lcmd - down  : yabai -m window --swap south || $(yabai -m window --display south && yabai -m display --focus south) || yabai -m window --move rel:0:8
shift + lcmd - up    : yabai -m window --swap north || $(yabai -m window --display north && yabai -m display --focus north) || yabai -m window --move rel:0:-8
shift + lcmd - right : yabai -m window --swap east || $(yabai -m window --display east && yabai -m display --focus east && yabai -m window --warp first) || yabai -m window --move rel:8:0

# Toggle window split (Omarchy: SUPER + J)
lcmd - j : yabai -m window --toggle split

# Move window to <NUMBER> space (Omarchy: SUPER SHIFT + <NUMBER>)
shift + ctrl - 1 : yabai -m window --space 1 --focus
shift + ctrl - 2 : yabai -m window --space 2 --focus
shift + ctrl - 3 : yabai -m window --space 3 --focus
shift + ctrl - 4 : yabai -m window --space 4 --focus

# Next space (Omarchy: SUPER + TAB)
#ctrl - tab         : yabai -m space --focus next || yabai -m space --focus first
ctrl - tab [
  "Messages" ~
  * : sh ~/.config/yabai/change_space.sh next
]

# Former space (Omarchy: SUPER CTRL + TAB)
#shift + ctrl - tab : yabai -m space --focus prev || yabai -m space --focus last
shift + ctrl - tab [
  "Messages" ~
  * : sh ~/.config/yabai/change_space.sh prev
]

# Mirror Space on X and Y Axis: shift + lalt - {x, y}
shift + lalt - up    : yabai -m space --mirror x-axis
shift + lalt - down  : yabai -m space --mirror x-axis
shift + lalt - left  : yabai -m space --mirror y-axis
shift + lalt - right : yabai -m space --mirror y-axis

