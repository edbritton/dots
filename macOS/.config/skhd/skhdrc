# Quicker lockscreen binding
fn - l : open -a ScreenSaverEngine && skhd -k 'ctrl + cmd - q'; nowplaying-cli pause

# Turn yabai on and off
fn - y : if pgrep -x yabai > /dev/null; then yabai --stop-service && brew services start autoraise; else yabai --start-service && brew services stop autoraise; fi

