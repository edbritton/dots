# Fork of <https://github.com/FelixKratz/dotfiles/blob/master/.config/skhd/skhdrc>
# also see <https://github.com/asmvik/dotfiles>
# some ideas <https://notes.alinpanaitiu.com/Keyboard-tricks-from-a-macOS-app-dev#fn-key>
# fn keys to avoid: A, C, D, N

# App keybindings (can be done with Shortcuts instead)
# Found the Shortcuts to be more reliable, when they actually run, these make sure the keybindings work more often
lcmd - return [
  * : { lsappinfo info -n "Terminal" 2>/dev/null | grep -q . && osascript -e 'tell app "Terminal" to do script "" activate'; } || open -a "Terminal"
  "Terminal" : skhd -k "cmd - n"
]
shift + lcmd - return   : shortcuts run 'Open browser' #osascript -e 'tell application "Safari" to make new document'
shift + lcmd - f        : open -a "Finder"
shift + lcmd - g        : open -a "Messages"
shift + lcmd - o        : open "obsidian://open?vault=standup"
shift + lalt + lcmd - o : open "obsidian://open?vault=screenplays"
shift + lcmd - y        : open -a "YouTube"

